# Environment Variables 环境变量配置示例
# Copy this file to .env.local and modify the values as needed

# 应用配置
VITE_APP_TITLE=Frontend Tech Blog
VITE_APP_DESCRIPTION=前端技术知识库
VITE_APP_VERSION=1.0.0

# 开发服务器配置
VITE_DEV_PORT=3000
VITE_DEV_HOST=localhost

# 生产环境配置
VITE_API_BASE_URL=https://api.example.com
VITE_USE_MOCK=false

# 功能开关
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_COMMENTS=false
VITE_ENABLE_SEARCH=true

# 主题配置
VITE_DEFAULT_THEME=light
VITE_PRIMARY_COLOR=#42b883

# SEO 配置
VITE_SITE_URL=https://example.com
VITE_SITE_NAME=前端技术知识库
